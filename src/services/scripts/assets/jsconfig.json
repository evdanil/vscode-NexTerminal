{
  "compilerOptions": {
    "checkJs": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "useUnknownInCatchVariables": false,
    "allowJs": true,
    "noEmit": true,
    "types": ["./types/nexus-scripts"]
  },
  "include": ["**/*.js"],
  "exclude": ["node_modules"]
}
